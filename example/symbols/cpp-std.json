{
  "name": "C++ standard library (supplemental)",
  "language": "C++",
  "note": "Name-only members merged into ts::stlMembers. Covers common std:: types the compiled table doesn't, across C++14–23. Extend freely; a bad file is ignored, not fatal.",
  "types": {
    "path": ["string", "c_str", "native", "generic_string", "filename", "stem", "extension",
      "parent_path", "root_name", "root_path", "relative_path", "has_extension", "has_filename",
      "has_parent_path", "is_absolute", "is_relative", "replace_extension", "replace_filename",
      "remove_filename", "append", "concat", "clear", "make_preferred", "empty", "compare",
      "lexically_normal", "lexically_relative", "begin", "end"],
    "error_code": ["value", "category", "message", "clear", "assign", "default_error_condition"],
    "thread": ["join", "detach", "joinable", "get_id", "native_handle", "swap"],
    "jthread": ["join", "detach", "joinable", "get_id", "get_stop_token", "get_stop_source",
      "request_stop", "swap"],
    "mutex": ["lock", "try_lock", "unlock", "native_handle"],
    "recursive_mutex": ["lock", "try_lock", "unlock", "native_handle"],
    "timed_mutex": ["lock", "try_lock", "try_lock_for", "try_lock_until", "unlock"],
    "shared_mutex": ["lock", "try_lock", "unlock", "lock_shared", "try_lock_shared", "unlock_shared"],
    "unique_lock": ["lock", "try_lock", "unlock", "owns_lock", "release", "mutex", "swap"],
    "lock_guard": [],
    "scoped_lock": [],
    "condition_variable": ["wait", "wait_for", "wait_until", "notify_one", "notify_all"],
    "future": ["get", "valid", "wait", "wait_for", "wait_until", "share"],
    "shared_future": ["get", "valid", "wait", "wait_for", "wait_until"],
    "promise": ["get_future", "set_value", "set_exception", "set_value_at_thread_exit", "swap"],
    "atomic": ["load", "store", "exchange", "compare_exchange_weak", "compare_exchange_strong",
      "fetch_add", "fetch_sub", "fetch_and", "fetch_or", "fetch_xor", "is_lock_free", "wait",
      "notify_one", "notify_all"],
    "duration": ["count", "zero", "min", "max"],
    "time_point": ["time_since_epoch", "min", "max"],
    "bitset": ["set", "reset", "flip", "test", "count", "size", "any", "none", "all",
      "to_string", "to_ulong", "to_ullong"],
    "variant": ["index", "valueless_by_exception", "emplace", "swap"],
    "any": ["reset", "has_value", "type", "emplace", "swap"],
    "regex": ["mark_count", "flags", "getloc"],
    "smatch": ["size", "empty", "str", "position", "length", "prefix", "suffix", "format",
      "begin", "end", "ready"],
    "cmatch": ["size", "empty", "str", "position", "length", "prefix", "suffix", "begin", "end"],
    "stringstream": ["str", "put", "get", "getline", "read", "write", "flush", "good", "eof",
      "fail", "bad", "clear", "tellg", "tellp", "seekg", "seekp"],
    "ostringstream": ["str", "put", "write", "flush", "tellp", "seekp", "good", "clear"],
    "istringstream": ["str", "get", "getline", "read", "tellg", "seekg", "good", "eof", "fail"],
    "ifstream": ["open", "close", "is_open", "get", "getline", "read", "good", "eof", "fail",
      "bad", "clear", "tellg", "seekg", "gcount", "peek", "unget"],
    "ofstream": ["open", "close", "is_open", "put", "write", "flush", "good", "fail", "clear",
      "tellp", "seekp"],
    "fstream": ["open", "close", "is_open", "get", "getline", "read", "put", "write", "flush",
      "good", "eof", "fail", "clear", "tellg", "tellp", "seekg", "seekp"],
    "span": ["size", "size_bytes", "empty", "front", "back", "data", "begin", "end", "first",
      "last", "subspan", "at"],
    "initializer_list": ["size", "begin", "end"]
  }
}
